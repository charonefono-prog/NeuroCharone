{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "ios": {
        "simulator": true,
        "env": {
          "INSTALL_LIGHTNINGCSS_DARWIN": "true"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "apk",
        "credentialsSource": "local"
      },
      "ios": {
        "credentialsSource": "remote",
        "env": {
          "INSTALL_LIGHTNINGCSS_DARWIN": "true"
        }
      }
    }
  },
  "submit": {
    "production": {}
  }
}
